<UserControl x:Class="SamplePlugin.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel>
        <TextBlock Text="示例插件设置"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <TextBlock Text="点击下面的按钮来测试插件功能："
                   FontSize="14"
                   Foreground="Gray"
                   Margin="0,0,0,20"/>

        <Button x:Name="OpenWhiteboardButton"
                Content="打开白板"
                Width="150"
                Height="40"
                FontSize="16"
                HorizontalAlignment="Left"
                Margin="0,0,0,10"/>

        <Button x:Name="CloseWhiteboardButton"
                Content="关闭白板"
                Width="150"
                Height="40"
                FontSize="16"
                HorizontalAlignment="Left"
                Margin="0,0,0,20"/>

        <Button x:Name="SwitchPrivilegeButton"
                Width="200"
                Height="40"
                FontSize="14"
                HorizontalAlignment="Left"
                Margin="0,0,0,10"/>

        <Button x:Name="RestartButton"
                Content="重启应用"
                Width="200"
                Height="40"
                FontSize="14"
                HorizontalAlignment="Left"
                Margin="0,0,0,10"/>

        <TextBlock x:Name="StatusText"
                   Text="等待操作..."
                   FontSize="14"
                   Foreground="Gray"
                   Margin="0,0,0,20"/>

        <TextBlock Text="工具栏组件示例"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,10,0,10"/>

        <TextBlock Text="以下组件已添加到工具栏组件库中，可在工具栏设置页面的组件库中找到："
                   FontSize="13"
                   Foreground="Gray"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>

        <Border BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="示例按钮 (sample.button)" FontWeight="Medium" FontSize="14"/>
                <TextBlock Text="示例普通组件，使用 ToolbarImageButton 控件。支持菜单样式设置：&#x0a;  • 普通弹窗 (PopupShellContent) - 带标题栏的弹窗&#x0a;  • 标签弹窗 (PopupTabShellContent) - 带标签标题栏的弹窗"
                           FontSize="12" Foreground="Gray" TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="示例自定义控件 (sample.customControl)" FontWeight="Medium" FontSize="14"/>
                <TextBlock Text="示例自定义控件插件，在工具栏中嵌入自定义控件。支持控制类型选择：&#x0a;  • 滑块 (Slider)&#x0a;  • 开关 (ToggleSwitch)&#x0a;  • 复选框 (CheckBox)&#x0a;  • 下拉框 (ComboBox)"
                           FontSize="12" Foreground="Gray" TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
